# =============================================================================
# Finance App — Production Environment Variables
# =============================================================================
# Issue: #771
#
# This file documents ALL environment variables required for a production
# Supabase deployment. Copy to your secrets manager — NEVER commit real values.
#
# Required for: Supabase Edge Functions, PowerSync, Auth providers
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase Project (set automatically by Supabase hosting)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ---------------------------------------------------------------------------
# Auth Configuration
# ---------------------------------------------------------------------------
# Shared secret between Supabase Auth and the auth-webhook Edge Function.
# Generate with: openssl rand -hex 32
AUTH_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# JWT secret from Supabase Dashboard → Settings → API → JWT Settings
JWT_SECRET=YOUR_JWT_SECRET

# ---------------------------------------------------------------------------
# WebAuthn / Passkey Configuration
# ---------------------------------------------------------------------------
WEBAUTHN_RP_NAME=Finance
WEBAUTHN_RP_ID=app.finance.example.com
WEBAUTHN_ORIGIN=https://app.finance.example.com

# ---------------------------------------------------------------------------
# CORS — Comma-separated list of allowed origins
# ---------------------------------------------------------------------------
# Include ALL client origins (web app, mobile deep links via web views)
ALLOWED_ORIGINS=https://app.finance.example.com

# ---------------------------------------------------------------------------
# Edge Function Secrets
# ---------------------------------------------------------------------------
# Secret for cron-triggered functions (process-recurring, maintenance).
# Generate with: openssl rand -hex 32
CRON_SECRET=YOUR_CRON_SECRET

# Comma-separated email addresses for admin dashboard access
ADMIN_EMAILS=admin@finance.example.com

# ---------------------------------------------------------------------------
# PowerSync Configuration
# ---------------------------------------------------------------------------
POWERSYNC_URL=https://YOUR_INSTANCE.powersync.journeyapps.com
POWERSYNC_PUBLIC_KEY=YOUR_POWERSYNC_PUBLIC_KEY

# ---------------------------------------------------------------------------
# Monitoring (optional)
# ---------------------------------------------------------------------------
# SENTRY_DSN=https://YOUR_SENTRY_DSN
# UPTIME_WEBHOOK_URL=https://YOUR_UPTIME_WEBHOOK
