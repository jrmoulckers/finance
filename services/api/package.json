{
  "name": "@finance/api",
  "version": "0.0.0",
  "private": true,
  "description": "Finance app — Supabase Edge Functions API and documentation",
  "license": "BUSL-1.1",
  "scripts": {
    "docs:api": "npx @redocly/cli preview-docs openapi.yaml",
    "docs:api:lint": "npx @redocly/cli lint openapi.yaml",
    "docs:api:bundle": "npx @redocly/cli bundle openapi.yaml -o docs/openapi-bundled.yaml",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:migrate": "supabase migration up",
    "supabase:status": "supabase status",
    "supabase:functions": "supabase functions serve",
    "setup": "bash scripts/setup-local.sh",
    "test:sync-contract": "deno test --allow-read supabase/tests/sync-contract.test.ts",
    "test:sync-integration": "psql postgresql://postgres:postgres@localhost:54322/postgres -f supabase/tests/sync-integration.test.sql"
  },
  "devDependencies": {
    "@redocly/cli": "^2.25.4",
    "yaml": "^2.8.3"
  }
}
