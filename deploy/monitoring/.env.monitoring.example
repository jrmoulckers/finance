# =============================================================================
# Finance App — Monitoring Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values:
#
#   cp .env.monitoring.example .env
#
# NEVER commit the .env file.
#
# Issues: #887
# =============================================================================

# ---------------------------------------------------------------------------
# Uptime Kuma
# ---------------------------------------------------------------------------
# Port for Uptime Kuma dashboard (direct access, no proxy)
MONITOR_PORT=3001

# ---------------------------------------------------------------------------
# Monitoring Caddy Proxy (optional — for HTTPS access)
# ---------------------------------------------------------------------------
# Domain for the monitoring dashboard
MONITOR_DOMAIN=monitor.YOUR_DOMAIN_HERE

# Email for Let's Encrypt certificate registration
MONITOR_TLS_EMAIL=YOUR_EMAIL_HERE

# Ports for the monitoring proxy
MONITOR_HTTP_PORT=8080
MONITOR_HTTPS_PORT=8443
