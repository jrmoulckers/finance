# =============================================================================
# Finance App — Staging Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values for the staging VPS:
#
#   cp .env.staging.example .env
#
# Then start with:
#   docker compose -f docker-compose.yml -f docker-compose.staging.yml up -d
#
# NEVER commit the .env file. It is listed in .gitignore.
#
# Issues: #883
# =============================================================================

# ---------------------------------------------------------------------------
# Domain & TLS
# ---------------------------------------------------------------------------
# Staging subdomain (e.g. staging.finance.example.com)
DOMAIN=staging.YOUR_DOMAIN_HERE

# Email for Let's Encrypt certificate registration
TLS_EMAIL=YOUR_EMAIL_HERE

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=YOUR_STAGING_POSTGRES_PASSWORD_HERE
POSTGRES_DB=postgres
POSTGRES_USER=supabase_admin
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# JWT (must be the same across ALL services)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=YOUR_STAGING_JWT_SECRET_HERE

# ---------------------------------------------------------------------------
# Supabase Service Keys
# ---------------------------------------------------------------------------
# Generate anon and service_role JWTs signed with your staging JWT_SECRET.
# Use https://supabase.com/docs/guides/self-hosting#api-keys to generate.
ANON_KEY=YOUR_STAGING_ANON_KEY_HERE
SERVICE_ROLE_KEY=YOUR_STAGING_SERVICE_ROLE_KEY_HERE

# ---------------------------------------------------------------------------
# Auth (GoTrue)
# ---------------------------------------------------------------------------
SITE_URL=https://staging.YOUR_DOMAIN_HERE

# Comma-separated list of allowed OAuth redirect URLs
AUTH_REDIRECT_URLS=https://staging.YOUR_DOMAIN_HERE/auth/callback,com.finance.staging://auth/callback

JWT_EXPIRY=3600

# Staging-specific: higher rate limits for testing
AUTH_RATE_LIMIT_EMAIL=100
AUTH_RATE_LIMIT_REFRESH=300

# Auto-confirm signups in staging (set via docker-compose.staging.yml override)
MAILER_AUTOCONFIRM=true

# ---------------------------------------------------------------------------
# SMTP (required for email auth — can use Mailtrap or similar for staging)
# ---------------------------------------------------------------------------
SMTP_HOST=YOUR_STAGING_SMTP_HOST_HERE
SMTP_PORT=587
SMTP_USER=YOUR_STAGING_SMTP_USER_HERE
SMTP_PASS=YOUR_STAGING_SMTP_PASSWORD_HERE
SMTP_ADMIN_EMAIL=noreply@staging.YOUR_DOMAIN_HERE
SMTP_SENDER_NAME=Finance App (Staging)

# ---------------------------------------------------------------------------
# OAuth — Apple (disabled for staging by default)
# ---------------------------------------------------------------------------
APPLE_AUTH_ENABLED=false
APPLE_CLIENT_ID=
APPLE_SECRET=

# ---------------------------------------------------------------------------
# OAuth — Google (optional for staging)
# ---------------------------------------------------------------------------
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=

# ---------------------------------------------------------------------------
# WebAuthn / Passkeys
# ---------------------------------------------------------------------------
WEBAUTHN_RP_NAME=Finance App (Staging)
WEBAUTHN_RP_ID=staging.YOUR_DOMAIN_HERE
WEBAUTHN_ORIGIN=https://staging.YOUR_DOMAIN_HERE

# ---------------------------------------------------------------------------
# Edge Functions
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
AUTH_WEBHOOK_SECRET=YOUR_STAGING_WEBHOOK_SECRET_HERE

# Generate with: openssl rand -hex 32
CRON_SECRET=YOUR_STAGING_CRON_SECRET_HERE

ALLOWED_ORIGINS=https://staging.YOUR_DOMAIN_HERE

EDGE_FUNCTIONS_PATH=../services/api/supabase/functions

# ---------------------------------------------------------------------------
# PowerSync (#881)
# ---------------------------------------------------------------------------
POWERSYNC_URL=https://staging.YOUR_DOMAIN_HERE/sync
POWERSYNC_PUBLIC_KEY=YOUR_STAGING_POWERSYNC_PUBLIC_KEY_HERE
POWERSYNC_SUPABASE_PROJECT_ID=YOUR_STAGING_SUPABASE_PROJECT_ID_HERE
POWERSYNC_JWKS_URI=

# MongoDB for PowerSync bucket storage
# Generate password with: openssl rand -base64 24
POWERSYNC_MONGO_URI=mongodb://powersync:YOUR_STAGING_MONGO_PASSWORD_HERE@mongo:27017/powersync?authSource=admin&replicaSet=rs0
MONGO_USER=powersync
MONGO_PASSWORD=YOUR_STAGING_MONGO_PASSWORD_HERE
MONGO_PORT=27017

POWERSYNC_SYNC_RULES_PATH=../services/api/powersync

# ---------------------------------------------------------------------------
# Sentry Error Monitoring (#1254)
# ---------------------------------------------------------------------------
# Staging Sentry DSNs — use separate Sentry projects from production
# to keep staging noise out of production dashboards.
# See docs/ops/monitoring-setup.md for full configuration guide.

SENTRY_ORG=
SENTRY_AUTH_TOKEN=

SENTRY_DSN_WEB=
SENTRY_DSN_ANDROID=
SENTRY_DSN_IOS=
SENTRY_DSN_WINDOWS=

SENTRY_ENVIRONMENT=staging

# ---------------------------------------------------------------------------
# Backups
# ---------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=7
