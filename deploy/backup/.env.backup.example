# =============================================================================
# Finance App — Backup Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before running backups:
#
#   cp .env.backup.example .env
#
# NEVER commit the .env file.
#
# Issues: #900
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL Connection
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=supabase_admin
PGPASSWORD=YOUR_POSTGRES_PASSWORD_HERE

# ---------------------------------------------------------------------------
# Backup Configuration
# ---------------------------------------------------------------------------
# Local directory to store backups
BACKUP_DIR=./volumes/db/backups

# Number of days to keep local backups
BACKUP_RETENTION_DAYS=30

# AES-256 encryption passphrase for backup files
# Generate with: openssl rand -base64 32
# CRITICAL: Store this separately from the backups! If you lose this key,
# you CANNOT decrypt your backups. Store it in a password manager or
# a separate secure location.
BACKUP_ENCRYPTION_KEY=YOUR_BACKUP_ENCRYPTION_KEY_HERE

# ---------------------------------------------------------------------------
# S3 Off-site Storage (optional — required for --upload flag)
# ---------------------------------------------------------------------------
# Works with AWS S3, Backblaze B2, MinIO, DigitalOcean Spaces, etc.

# S3 bucket name
S3_BUCKET=YOUR_BACKUP_BUCKET_HERE

# Key prefix within the bucket
S3_PREFIX=finance-backups/

# S3 endpoint URL (leave empty for AWS S3, set for other providers)
# Examples:
#   Backblaze B2: https://s3.us-west-004.backblazeb2.com
#   DigitalOcean: https://nyc3.digitaloceanspaces.com
#   MinIO: https://minio.example.com
S3_ENDPOINT=

# AWS credentials (or S3-compatible credentials)
AWS_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_S3_SECRET_KEY_HERE
