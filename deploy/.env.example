# =============================================================================
# Finance App — Self-Hosted Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before starting:
#
#   cp .env.example .env
#
# NEVER commit the .env file. It is listed in .gitignore.
#
# Issue: #268
# =============================================================================

# ---------------------------------------------------------------------------
# Domain & TLS
# ---------------------------------------------------------------------------
# Your fully qualified domain name (e.g. finance.jrmoulckers.com)
DOMAIN=YOUR_DOMAIN_HERE

# Email for Let's Encrypt certificate registration
TLS_EMAIL=YOUR_EMAIL_HERE

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD_HERE
POSTGRES_DB=postgres
POSTGRES_USER=supabase_admin
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# JWT (must be the same across ALL services)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=YOUR_JWT_SECRET_HERE

# ---------------------------------------------------------------------------
# Supabase Service Keys
# ---------------------------------------------------------------------------
# Generate anon and service_role JWTs signed with your JWT_SECRET.
# Use https://supabase.com/docs/guides/self-hosting#api-keys to generate.
ANON_KEY=YOUR_ANON_KEY_HERE
SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ---------------------------------------------------------------------------
# Auth (GoTrue)
# ---------------------------------------------------------------------------
# The URL your frontend app lives at
SITE_URL=https://YOUR_DOMAIN_HERE

# Comma-separated list of allowed OAuth redirect URLs
AUTH_REDIRECT_URLS=https://YOUR_DOMAIN_HERE/auth/callback,com.finance.app://auth/callback

# JWT expiry in seconds (default: 3600 = 1 hour)
JWT_EXPIRY=3600

# Rate limits
AUTH_RATE_LIMIT_EMAIL=30
AUTH_RATE_LIMIT_REFRESH=150

# Session lifecycle
# Maximum session duration before forced re-authentication (default: 24h)
SESSION_TIMEBOX=24h
# Inactivity timeout before session expires (default: 1h)
SESSION_INACTIVITY_TIMEOUT=1h

# Auto-confirm email signups (set to true only for testing)
MAILER_AUTOCONFIRM=false

# Optional web beta/staging account allowlist. Leave empty for production.
VITE_BETA_ALLOWED_EMAILS=

# ---------------------------------------------------------------------------
# SMTP (required for email auth, magic links, password reset)
# ---------------------------------------------------------------------------
SMTP_HOST=YOUR_SMTP_HOST_HERE
SMTP_PORT=587
SMTP_USER=YOUR_SMTP_USER_HERE
SMTP_PASS=YOUR_SMTP_PASSWORD_HERE
SMTP_ADMIN_EMAIL=noreply@YOUR_DOMAIN_HERE
SMTP_SENDER_NAME=Finance App

# ---------------------------------------------------------------------------
# OAuth — Apple (optional, leave empty to disable)
# ---------------------------------------------------------------------------
APPLE_AUTH_ENABLED=false
APPLE_CLIENT_ID=
APPLE_SECRET=

# ---------------------------------------------------------------------------
# OAuth — Google (optional, leave empty to disable)
# ---------------------------------------------------------------------------
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=

# ---------------------------------------------------------------------------
# WebAuthn / Passkeys
# ---------------------------------------------------------------------------
WEBAUTHN_RP_NAME=Finance App
WEBAUTHN_RP_ID=YOUR_DOMAIN_HERE
WEBAUTHN_ORIGIN=https://YOUR_DOMAIN_HERE

# ---------------------------------------------------------------------------
# Edge Functions
# ---------------------------------------------------------------------------
# Shared secret for auth webhook verification
# Generate with: openssl rand -hex 32
AUTH_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# Shared secret for cron-triggered functions (process-recurring)
# Generate with: openssl rand -hex 32
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://YOUR_DOMAIN_HERE

# Path to edge functions source (relative to docker-compose.yml)
EDGE_FUNCTIONS_PATH=../services/api/supabase/functions

# Path to the web app build output (relative to docker-compose.yml)
WEB_DIST_PATH=../apps/web/dist

# ---------------------------------------------------------------------------
# PowerSync (offline-first sync engine) — #881
# ---------------------------------------------------------------------------
POWERSYNC_URL=YOUR_POWERSYNC_URL_HERE
POWERSYNC_PUBLIC_KEY=YOUR_POWERSYNC_PUBLIC_KEY_HERE

# MongoDB connection URI for PowerSync bucket storage.
# IMPORTANT: If the password contains special characters (/ + = etc.),
# they must be URL-encoded (e.g., / → %2F, + → %2B, = → %3D).
# Use: python3 -c "import urllib.parse; print(urllib.parse.quote('YOUR_PASSWORD'))"
# Format: mongodb://<user>:<password>@mongo:27017/powersync?authSource=admin&replicaSet=rs0
POWERSYNC_MONGO_URI=mongodb://powersync:YOUR_MONGO_PASSWORD_HERE@mongo:27017/powersync?authSource=admin&replicaSet=rs0

# MongoDB credentials (used by the mongo container)
MONGO_USER=powersync
MONGO_PASSWORD=YOUR_MONGO_PASSWORD_HERE

# Path to sync rules file (relative to docker-compose.yml)
POWERSYNC_SYNC_RULES_PATH=../services/api/powersync

# ---------------------------------------------------------------------------
# Backups (used by the backup script)
# ---------------------------------------------------------------------------
# Number of daily backups to retain
BACKUP_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Sentry Error Monitoring (#1254)
# ---------------------------------------------------------------------------
# Create projects at https://sentry.io — one per platform.
# DSNs are project-specific ingest URLs; auth token is org-level.
# See docs/ops/monitoring-setup.md for full configuration guide.

# Sentry organization slug (e.g. "finance-app")
SENTRY_ORG=

# Org-level auth token for source map / ProGuard / dSYM uploads
# Generate at: https://sentry.io/settings/auth-tokens/
# Scopes required: project:releases, org:ci
SENTRY_AUTH_TOKEN=

# Per-platform DSNs (each maps to a separate Sentry project)
SENTRY_DSN_WEB=
SENTRY_DSN_ANDROID=
SENTRY_DSN_IOS=
SENTRY_DSN_WINDOWS=

# Environment tag sent with all events (production, staging, debug)
SENTRY_ENVIRONMENT=production

# ---------------------------------------------------------------------------
# CI/CD Deployment (GitHub Actions secrets — not needed in .env)
# ---------------------------------------------------------------------------
# These values are configured as environment-scoped GitHub Secrets
# (scoped to `staging` or `production` GitHub Environments), not in this file.
# Listed here for documentation purposes only.
# See docs/ops/infrastructure-standards.md §6 for naming conventions.
#
# SUPABASE_URL          — Supabase project URL (env-scoped)
# SUPABASE_ANON_KEY     — Supabase anonymous key (env-scoped)
# POWERSYNC_URL         — PowerSync endpoint (env-scoped)
# DEPLOY_HOST           — Server hostname for SSH (env-scoped)
# DEPLOY_SSH_KEY        — Server SSH private key (env-scoped)
# DEPLOY_USER           — Server SSH user (env-scoped)
#
# VERCEL_TOKEN          — Vercel deployment token (env-scoped)
# VERCEL_ORG_ID         — Vercel organization ID (env-scoped)
# VERCEL_PROJECT_ID     — Vercel project ID (env-scoped)
