{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json", "tsconfig*.json"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": [
        "src/**",
        "test/**",
        "tests/**",
        "__tests__/**",
        "*.test.*",
        "*.spec.*",
        "package.json",
        "tsconfig.json"
      ],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "test/**",
        "tests/**",
        "__tests__/**",
        "*.ts",
        "*.tsx",
        "*.js",
        "*.jsx",
        ".eslintrc.*",
        "eslint.config.*",
        "package.json",
        "tsconfig.json"
      ],
      "outputs": [],
      "cache": true
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "tests/**", "package.json", "tsconfig.json", "tsconfig*.json"],
      "outputs": [],
      "cache": true
    },
    "format": {
      "inputs": ["src/**", "test/**", "tests/**", "*.ts", "*.tsx", "*.js", "*.jsx", "*.json", "*.md"],
      "outputs": [],
      "cache": false
    }
  }
}
