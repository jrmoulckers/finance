# Finance App — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env!

# Supabase (required for backend sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# PowerSync (required for offline sync)
POWERSYNC_URL=https://your-instance.powersync.journeyapps.com

# OAuth Providers (optional — configure in Supabase Dashboard)
GOOGLE_CLIENT_ID=your-google-client-id
APPLE_SERVICES_ID=your-apple-services-id

# Development
NODE_ENV=development
