# EditorConfig — Finance Monorepo
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{swift,kt,kts}]
indent_size = 4

[*.{cs,csproj}]
indent_size = 4

[*.py]
indent_size = 4

[Makefile]
indent_style = tab
