{
  "name": "finance",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-platform, native-first financial tracking application",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "tools/*"
  ],
  "scripts": {
    "build": "npm run build:kmp && turbo run build",
    "build:kmp": "node tools/gradle.js build -x jsBrowserTest -x allTests",
    "build:tokens": "npm run build -w packages/design-tokens",
    "tokens:preview": "node tools/token-preview-serve.mjs",
    "tokens:preview:generate": "node tools/token-preview-generate.mjs",
    "test": "npm run test:kmp && turbo run test",
    "test:kmp": "node tools/gradle.js :packages:core:jvmTest",
    "test:web": "npm run test -w apps/web",
    "lint": "turbo run lint && npx eslint . --max-warnings 0",
    "lint:fix": "npx prettier --write . && npx eslint . --fix",
    "type-check": "turbo run type-check",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "ci:check": "npm run format:check && npm run lint && npm run type-check",
    "ci:check:quick": "node tools/ci-check-quick.js",
    "ready-for-pr": "node tools/ready-for-pr.js",
    "clean": "node tools/gradle.js clean && turbo run clean",
    "cleanup:worktrees": "node tools/cleanup-worktrees.js",
    "agent:worktree": "node tools/agent-scripts/setup-worktree.js",
    "agent:check": "node tools/agent-scripts/pre-push-check.js",
    "agent:pr": "node tools/agent-scripts/create-pr.js",
    "agent:rebase": "node tools/agent-scripts/rebase-and-push.js",
    "agent:status": "node tools/agent-scripts/sprint-status.js",
    "agent:issues": "node tools/agent-scripts/list-issues.js",
    "agent:pr-status": "node tools/agent-scripts/check-pr-status.js",
    "setup": "node tools/setup.js",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml,md,css,html}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "finance",
    "budgeting",
    "personal-finance",
    "monorepo"
  ],
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/jrmoulckers/finance.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.4",
  "overrides": {
    "dompurify": ">=3.4.1",
    "fast-xml-parser": ">=5.7.0",
    "protobufjs": ">=7.5.5",
    "brace-expansion": ">=5.0.6||<5.0.0",
    "postcss": ">=8.5.10",
    "styled-components": ">=6.4.1",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript-eslint": "^8.60.1"
  }
}
