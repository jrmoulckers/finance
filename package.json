{
  "name": "finance",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-platform, native-first financial tracking application",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "tools/*"
  ],
  "scripts": {
    "build": "npm run build:kmp && turbo run build",
    "build:kmp": "node tools/gradle.js build -x jsBrowserTest -x allTests",
    "build:tokens": "npm run build -w packages/design-tokens",
    "test": "npm run test:kmp && turbo run test",
    "test:kmp": "node tools/gradle.js :packages:core:jvmTest",
    "lint": "turbo run lint && npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "type-check": "turbo run type-check",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "clean": "node tools/gradle.js clean && turbo run clean",
    "setup": "node tools/setup.js",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "keywords": [
    "finance",
    "budgeting",
    "personal-finance",
    "monorepo"
  ],
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/jrmoulckers/finance.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.4",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "turbo": "^2.8.13",
    "typescript-eslint": "^8.56.1"
  }
}
